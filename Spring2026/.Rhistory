seasons_chloro <- mean_chloro|> filter(!is.na(season))|>
ggplot()+
geom_point(aes(year, mean_chloro, color = season))+
scale_color_viridis_d()+
labs(title = "Mean Seasonal Chlorofluorocarbon Levels by Year")
seasons_chloro
# Chunk 60
"
Notes: During the meeting on 2/23 we discussed
Plotting values without separating by season
#Box plots
"
#Plotting mean temp by year
mean_yearly_temperature <- mean_temp|> filter(!is.na(season))|>
ggplot()+
geom_boxplot(aes(year, mean_temp))+
facet_wrap(~year)+
labs(title = "Mean Yearly Temperature")+
theme(
legend.position = "none"
)
mean_yearly_temperature
# Chunk 61
#Comparing the first and last year of collected data
temp2002Vs2021 <- mean_temp|> filter(!is.na(mean_temp))|>
filter(year== c(2002, 2021))|>
ggplot()+
geom_boxplot(aes(year, mean_temp))+
facet_wrap(~year)+
labs(title = "Mean Yearly Temperature")
temp2002Vs2021
# Chunk 62
#Chloro levels by year (not separated by season)
mean_yearly_chloro <- mean_chloro|> filter(!is.na(mean_chloro))|>
ggplot()+
geom_boxplot(aes(year, mean_chloro))+
facet_wrap(~year)+
labs(title = "Mean Yearly Chlorofluorocarbon Levels")
mean_yearly_chloro
View(sc_02_21_raw)
library(readr)
library(tidyverse)
library(dplyr)
library(lubridate)
library(janitor)
library(stringr)
library(reshape2)
#creates a folder for the new data
dir.create("data/stony_creek", recursive = TRUE, showWarnings = FALSE)
## downloading Stony Creek data file from the web
#creating a temporary zip file
zip_sc <- tempfile(fileext = ".zip")
link_stony_creek <- "http://cdmo.baruch.sc.edu/aqs/output/334470.zip"
download.file(link_stony_creek, zip_sc, mode = "wb")
#unzipping data from zipfile and placing it in a folder
unzip(zip_sc, exdir = "data/stony_creek")
#read in the files for all the years as a one data file using regex (regular expressions)
files <- list.files(
"data/stony_creek",
pattern = "^hudscwq[0-9]{4}\\.csv$", # ^ -starts a string, hudscwq - the exact name in the file (constant), any digits from 0-9 might follow, {4} - we are looking for 4 digits pattern, \\. - there should be a dot, csv - it should end with "csv",  end a string
full.names = TRUE
)
stony_creek_raw <- do.call(
rbind,
lapply(files, function(f) {
df <- read.csv(f, fileEncoding = "Latin1")
df$year <- as.integer(gsub(".*([0-9]{4})\\.csv$", "\\1", f))
df
})
)
flagged_data <- "<-3>|<-2>|<1>"
flags <- c("F_Record",
"F_Temp",
"F_SpCond",
"F_Sal",
"F_DO_Pct",
"F_Depth",
"F_cDepth",
"F_Level",
"F_pH",
"F_Turb",
"F_ChlFluor",
"F_DO_mgl")
stony_creek <- stony_creek_raw |>
mutate(Temp = if_else(str_detect(F_Temp, flagged_data) & year != 2019, NA_real_, Temp),
SpCond = if_else(str_detect(F_SpCond, flagged_data), NA_real_, SpCond),
Sal = if_else(str_detect(F_Sal, flagged_data), NA_real_, Sal),
DO_Pct = if_else(str_detect(F_DO_Pct, flagged_data), NA_real_, DO_Pct),
Depth = if_else(str_detect(F_Depth, flagged_data), NA_real_, Depth),
cDepth = if_else(str_detect(F_cDepth, flagged_data), NA_real_, cDepth),
pH = if_else(str_detect(F_pH, flagged_data), NA_real_, pH),
Turb = if_else(str_detect(F_Turb, flagged_data), NA_real_, Turb),
ChlFluor = if_else(str_detect(F_ChlFluor, flagged_data), NA_real_, ChlFluor),
DO_mgl = if_else(str_detect(DO_mgl, flagged_data), NA_real_, DO_mgl)
)
stony_creek <- stony_creek_raw |>
mutate(Temp = if_else(str_detect(F_Temp, flagged_data) & year != 2019, NA_real_, Temp),
SpCond = if_else(str_detect(F_SpCond, flagged_data) & year != 2019, NA_real_, SpCond),
Sal = if_else(str_detect(F_Sal, flagged_data) & year != 2019, NA_real_, Sal),
DO_Pct = if_else(str_detect(F_DO_Pct, flagged_data) & year != 2019, NA_real_, DO_Pct),
Depth = if_else(str_detect(F_Depth, flagged_data) & year != 2019, NA_real_, Depth),
cDepth = if_else(str_detect(F_cDepth, flagged_data) & year != 2019, NA_real_, cDepth),
pH = if_else(str_detect(F_pH, flagged_data) & year != 2019, NA_real_, pH),
Turb = if_else(str_detect(F_Turb, flagged_data) & year != 2019, NA_real_, Turb),
ChlFluor = if_else(str_detect(F_ChlFluor, flagged_data) & year != 2019, NA_real_, ChlFluor),
DO_mgl = if_else(str_detect(DO_mgl, flagged_data) & year != 2019, NA_real_, DO_mgl)
)
# Removing empty columns and other irrelevant columns
stony_creek <- stony_creek |>
remove_empty("cols")|>
select(-StationCode,
-isSWMP, #historical and provisionalPlus columns indicate the status of QAQC
-Historical,
-ProvisionalPlus
)
#removing flag columns
stony_creek <- stony_creek %>% select(-all_of(flags))
