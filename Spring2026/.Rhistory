scale_factor <- max(spring_daily$Turb, na.rm = TRUE) /
max(spring_daily$TotPrcp, na.rm = TRUE)
ggplot(spring_daily, aes(x = date)) +
# Precipitation (bars)
geom_col(
aes(y = TotPrcp * scale_factor, fill = "Precipitation"),
alpha = 0.6
) +
# Turbidity (line)
geom_line(
aes(y = Turb, color = "Turbidity"),
linewidth = 1.1
) +
facet_wrap(~ year, scales = "free_x") +
scale_y_continuous(
name = "Turbidity",
sec.axis = sec_axis(~ . / scale_factor, name = "Precipitation")
) +
# Custom legend colors
scale_color_manual(
values = c("Turbidity" = "#2C7FB8")
) +
scale_fill_manual(
values = c("Precipitation" = "#F03B20")
) +
labs(
title = "Turbidity and Precipitation Over Time",
x = "Date",
color = "",
fill = ""
) +
scale_x_date(date_labels = "%b %d") +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold", size = 16),
strip.text = element_text(face = "bold"),
panel.grid.minor = element_blank(),
legend.position = "top"
)
