```{r, echo = FALSE, message=FALSE, warning=FALSE}
#libraries
library(tidyverse)
library(dplyr)
library(lubridate)
library(gt)
library(ggplot2)
library(stringr)
library(janitor)
library(reshape2)
library(ggpubr)
```



## Data



```{r}
combined <- read_csv("data/joined_dataset.csv")
```



## EDA



```{r}
#overview of variables and NAs
glimpse(combined) 

#summaries of all variables
summary(combined) 
```



### Plots

#### Correlation matrix



```{r}
#select meaningful numeric variables
cor_vars <- combined %>%
  select(
    ATemp, RH, BP, WSpd, MaxWSpd, Wdir, SDWDir, TotPAR, TotPrcp,  #weather
    Temp, DO_mgl, DO_Pct, Sal, SpCond, pH, Turb, ChlFluor, Depth   #water
  ) %>%
  select(where(~sum(!is.na(.)) > 0))#remove NA columns

#compute correlation matrix
cor_matrix <- cor(cor_vars, use = "pairwise.complete.obs")

#remove the upper triangle of the matrix
cor_matrix[upper.tri(cor_matrix)] <- NA

#melt for ggplot
cor_long <- melt(cor_matrix, na.rm = TRUE)
names(cor_long) <- c("Variable1", "Variable2", "Correlation")


#plot lower-triangle matrix
ggplot(cor_long, aes(x = Variable1, y = Variable2, fill = Correlation)) +
  geom_tile(color = "white") +
  scale_fill_gradient2(low = "#a6cee3", mid = "#f7f7f7", high = "#fb9a99", midpoint = 0) +
  geom_text(aes(label = round(Correlation, 2)), size = 3) +
  theme_minimal() +
  theme(
    axis.text.x = element_text(angle = 45, hjust = 1),
    panel.grid = element_blank()
  ) +
  labs(title = "Correlation Matrix", fill = "r")
```



#### Relationship between the variables



```{r}
#wind can affect oxygen mixing???
ggplot(combined, aes(x = WSpd, y = DO_mgl)) +
  geom_point(alpha = 0.2) +
  geom_smooth(method = "loess") +
  labs(x = "Wind speed (m/s)", y = "Dissolved Oxygen (mg/L)")
```

```{r}
#heavy rain may dilute salinity 
ggplot(combined, aes(x = TotPrcp, y = Sal)) +
  geom_point(alpha = 0.3) +
  geom_smooth(method = "loess") +
  labs(x = "Total Precipitation (mm)", y = "Salinity (ppt)")
```

```{r}
#photosynthesis response to light
ggplot(combined, aes(x = TotPAR, y = ChlFluor)) +
  geom_point(alpha = 0.2) +
  geom_smooth(method = "gam") +
  labs(x = "Total PAR", y = "Chlorophyll Fluorescence")
```



This looks crazy!



```{r}
#warmer air => dissolved oxygen decreases
ggplot(combined, aes(x = Temp, y = DO_mgl)) +
  geom_point(alpha = 0.05) +
  geom_smooth(method = "lm") +
  labs(x = "Air Temperature (°C)", y = "Dissolved Oxygen (mg/L)")
```

```{r}
test <- combined %>% 
  filter(DO_mgl>17.5)
```

```{r}
test_1 <- combined %>% 
  filter(year == 2009 & month == 5)
```

```{r}
#warmer air => dissolved oxygen decreases
ggplot(test_1, aes(x = Temp, y = DO_mgl)) +
  geom_point(alpha = 0.05) +
  geom_smooth(method = "lm") +
  labs(x = "Air Temperature (°C)", y = "Dissolved Oxygen (mg/L)")
```

```{r}
#temperature changes can influence pH through shifts in biological activity and gas solubility???
ggplot(combined, aes(x = ATemp, y = pH)) +
  geom_point(alpha = 0.05) +
  geom_smooth(method = "lm") +
  labs(x = "Air Temperature (°C)", y = "pH")
```

```{r}
#changes in atmospheric pressure can slightly affect water level measurements 
ggplot(combined, aes(x = BP, y = Depth)) +
  geom_point(alpha = 0.05) +
  geom_smooth(method = "lm") +
  labs(x = "BP", y = "Depth")
```

```{r}
#high turbidity can reduce light penetration, potentially limiting chlorophyll production
ggplot(combined, aes(x = TotPrcp, y = Sal)) +
  geom_point(alpha = 0.3) +
  geom_smooth(method = "loess") +
  labs(x = "Total Precipitation (mm)", y = "Salinity (ppt)")
```



#### Total Precipitation (Totprc)

What can explain the precipitation?



```{r}
#RH

combined %>%
  filter(!is.na(RH), !is.na(TotPrcp), !is.na(season)) %>%
  ggplot(aes(x = RH, y = TotPrcp)) +
  geom_point(alpha = 0.4, color = "#2C7BB6", size = 1.8) +
  geom_smooth(method = "lm", se = TRUE, color = "#D7191C", linewidth = 1) +
  facet_wrap(~ season) +
  labs(
    title = "Relationship Between Total Precipitation and RH by Season",
    x = "RH",
    y = "Total Precipitation"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    plot.title = element_text(face = "bold", size = 16),
    plot.subtitle = element_text(size = 12),
    strip.text = element_text(face = "bold"),
    panel.grid.minor = element_blank()
  )
```

```{r}
#relative humidity
ggplot(combined, aes(x = RH, y = TotPrcp)) +
  geom_point(alpha = 0.3) +
  geom_smooth(method = "lm") +
  labs(x = "RH", y = "Total Precipitation (mm)")+
  ylim(0,20)

```

