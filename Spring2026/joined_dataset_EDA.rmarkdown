Trends over time (STILL WORK IN PROGRESS!!!)



```{r}
#new column to proxy for time
combined <- combined %>%
  mutate(
    year = year(DateTimeStamp),
    doy = yday(DateTimeStamp),  #day of year (1–365)
    decimal_year = year + (doy - 1)/365 #smooth time variable
  )
```



Increase of air temperature



```{r}
daily <- combined %>%
  group_by(date) %>%
  summarise(
    mean_ATemp = mean(ATemp, na.rm = TRUE),
    mean_Temp = mean(Temp, na.rm = TRUE),
    total_Prcp = sum(TotPrcp, na.rm = TRUE)
  ) %>%
  mutate(decimal_year = year(date) + (yday(date)-1)/365)
```

```{r}
#plot the relationship
ggplot(daily, aes(x = decimal_year, y = mean_ATemp)) +
  geom_point(alpha = 0.2) +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Air Temperature Trend Over Time",
       x = "Year", y = "Mean Air Temp")
```



Temperature Outliers/Anomalies



```{r}
daily <- daily %>%
  mutate(doy = yday(date)) %>%
  group_by(doy) %>%
  mutate(
    clim_ATemp = mean(mean_ATemp, na.rm = TRUE),
    anomaly_ATemp = mean_ATemp - clim_ATemp
  ) %>%
  ungroup()
```

```{r}
#plot the relationship
ggplot(daily, aes(x = decimal_year, y = anomaly_ATemp)) +
  geom_point(alpha = 0.2) +
  geom_smooth(method = "lm", color = "blue") +
  labs(title = "Air Temperature Anomalies Over Time")
```



Extreme rainfall events



```{r}
#define what is considered extreme
threshold <- quantile(daily$total_Prcp, 0.95, na.rm = TRUE)

daily <- daily %>%
  mutate(extreme_rain = total_Prcp > threshold)

#count per year
rain_extremes <- daily %>%
  group_by(year(date)) %>%
  summarise(extreme_days = sum(extreme_rain, na.rm = TRUE))

#plot the relationship
ggplot(rain_extremes, aes(x = `year(date)`, y = extreme_days)) +
  geom_line() +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Extreme Rainfall Events per Year")

```



Extreme temperature changes



```{r}
daily <- daily %>%
  arrange(date) %>%
  mutate(
    temp_change = abs(mean_ATemp - lag(mean_ATemp)),
    extreme_temp_change = temp_change > quantile(temp_change, 0.95, na.rm = TRUE)
  )
```

```{r}
temp_extremes <- daily %>%
  group_by(year(date)) %>%
  summarise(extreme_changes = sum(extreme_temp_change, na.rm = TRUE))
```

```{r}
#plot the relationship
ggplot(temp_extremes, aes(x = `year(date)`, y = extreme_changes)) +
  geom_line() +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Extreme temperature changes per Year")
```



Heat events



```{r}
heat_threshold <- quantile(daily$mean_ATemp, 0.95, na.rm = TRUE)

daily <- daily %>%
  mutate(heat_day = mean_ATemp > heat_threshold)
```

```{r}
daily %>%
  group_by(year(date)) %>%
  summarise(heat_days = sum(heat_day, na.rm = TRUE))
```

```{r}
heat_yearly <- daily %>%
  group_by(year = year(date)) %>%
  summarise(heat_days = sum(heat_day, na.rm = TRUE))
```

```{r}
ggplot(heat_yearly, aes(x = year, y = heat_days)) +
  geom_line() +
  geom_smooth(method = "lm", color = "red") +
  labs(title = "Heat Days per Year",
       x = "Year",
       y = "Number of Heat Days")
```



Monthly changes



```{r}
monthly_heat <- daily %>%
  mutate(
    year = year(date),
    month = month(date)
  ) %>%
  group_by(year, month) %>%
  summarise(
    heat_days = sum(heat_day, na.rm = TRUE),
    .groups = "drop"
  )
```

```{r}
ggplot(monthly_heat, aes(x = year + (month-1)/12, y = heat_days)) +
  geom_line(alpha = 0.5) +
  geom_smooth(method = "lm", color = "red") +
  labs(
    title = "Monthly Heat Events Over Time",
    x = "Year",
    y = "Number of Heat Days"
  )
```

